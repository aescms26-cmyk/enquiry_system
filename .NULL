c:/Users/krish/Downloads/ambasador/Amba/src/components/student-portal/HeroSection.css

.hero-section {
  position: relative;
  min-height: 80vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  margin: 0 1rem;
}

@media (min-width: 768px) {
  .hero-section {
    margin: 0 5rem;
  }
}

.hero-background {
  position: absolute;
  inset: 0;
}

.hero-background-light {
  background: linear-gradient(to bottom right, #f8fafc, #eff6ff, #f1f5f9);
}

.hero-blob {
  position: absolute;
  border-radius: 50%;
  filter: blur(120px);
}

.hero-blob-red {
  top: 0;
  right: 0;
  width: 800px;
  height: 800px;
  background-color: rgba(211, 47, 47, 0.1);
  transform: translateY(-50%) translateX(25%);
}

.hero-blob-blue {
  bottom: 0;
  left: 0;
  width: 600px;
  height: 600px;
  background-color: rgba(37, 99, 235, 0.05);
  transform: translateY(50%) translateX(-25%);
}

.hero-blob-emerald {
  top: 50%;
  left: 50%;
  width: 500px;
  height: 500px;
  background-color: rgba(16, 185, 129, 0.1);
  transform: translate(-50%, -50%);
}

.hero-grid-pattern {
  position: absolute;
  inset: 0;
  background-image: radial-gradient(circle, currentColor 0.5px, transparent 0.5px);
  background-size: 40px 40px;
}

.hero-grid-pattern-dark {
  color: rgba(255, 255, 255, 0.2);
}

.hero-grid-pattern-light {
  color: rgba(25, 118, 210, 0.1);
}

.hero-bottom-blend {
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;  
  height: 16rem;
  background: linear-gradient(to top, var(--bg-body), transparent);
}

.hero-content {
  position: relative;
  z-index: 10;
  width: 100%;
  padding: 0 0.5rem;
}

@media (min-width: 640px) {
  .hero-content {
    padding: 0 1.5rem;
  }
}

@media (min-width: 1024px) {
  .hero-content {
    padding: 0 2rem;
  }
}

.hero-overline {
  color: var(--accent-red);
  font-size: 0.875rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  margin-bottom: 1.5rem;
  display: block;
}

@media (min-width: 768px) {
  .hero-overline {
    font-size: 1rem;
  }
}

.hero-title {
  font-size: 2.5rem;
  font-weight: 900;
  margin-bottom: 2rem;
  letter-spacing: -0.05em;
  line-height: 1;
}

.hero-title-dark {
  color: #ffffff;
}

.hero-title-light {
  color: #0f172a;
}

@media (min-width: 768px) {
  .hero-title {
    font-size: 5rem;
    line-height: 0.9;
  }
}

@media (min-width: 1024px) {
  .hero-title {
    font-size: 6rem;
  }
}

.hero-title-accent {
  background-clip: text;
  -webkit-background-clip: text;
  color: transparent;
  background-image: linear-gradient(
    to right,
    var(--accent-red),
    var(--accent-blue),
    var(--accent-red)
  );
  background-size: 200% auto;
  animation: gradient 8s linear infinite;
}

.hero-description {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  margin: 2rem 0;
}

@media (min-width: 768px) {
  .hero-description {
    gap: 1.5rem;
    margin: 3rem 0;
  }
}

.hero-description-bar {
  width: 0.375rem;
  height: 4rem;
  background-color: var(--accent-red);
  border-radius: 9999px;
  margin-top: 0.15rem;
  flex-shrink: 0;
}

@media (min-width: 768px) {
  .hero-description-bar {
    height: 7rem;
  }
}

.hero-description-text {
  margin-top: 0.5rem;
  font-size: 1rem;
  font-weight: 700;
  line-height: 1.625;
  max-width: 42rem;
}

.hero-description-text-dark {
  color: #cbd5e1;
}

.hero-description-text-light {
  color: #475569;
}

@media (min-width: 768px) {
  .hero-description-text {
    font-size: 1.5rem;
    margin-top: 1rem;
  }
}

.hero-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 1rem;
}

@media (min-width: 768px) {
  .hero-actions {
    gap: 1.5rem;
  }
}

.hero-button {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem 1.5rem;
  border-radius: 9999px;
  font-size: 0.75rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  border: none;
  cursor: pointer;
  transition: all 0.2s;
}

@media (min-width: 768px) {
  .hero-button {
    padding: 1.25rem 2.5rem;
    font-size: 0.875rem;
  }
}

.hero-button-primary {
  background-color: var(--accent-red);
  color: #ffffff;
  box-shadow: 0 20px 25px -5px rgba(211, 47, 47, 0.2);
}

.hero-button-primary:hover {
  background-color: var(--accent-red-hover);
  box-shadow: 0 20px 25px -5px rgba(211, 47, 47, 0.4);
  transform: translateY(-0.25rem);
}

.hero-button-secondary-dark {
  background-color: rgba(255, 255, 255, 0.05);
  color: #ffffff;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.hero-button-secondary-dark:hover {
  background-color: rgba(255, 255, 255, 0.1);
  transform: translateY(-0.25rem);
}

.hero-button-secondary-light {
  background-color: #e2e8f0;
  color: #0f172a;
  border: 1px solid #cbd5e1;
}

.hero-button-secondary-light:hover {
  background-color: #cbd5e1;
  transform: translateY(-0.25rem);
}

.hero-scroll-indicator {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  display: none;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
}

@media (min-width: 768px) {
  .hero-scroll-indicator {
    display: flex;
  }
}

.hero-content-inner {
  max-width: 56rem;
}

.hero-send-icon {
  width: 1.25rem;
  height: 1.25rem;
}

@keyframes gradient {
  0% {
    background-position: 0% center;
  }
  100% {
    background-position: 200% center;
  }
}

c:/Users/krish/Downloads/ambasador/Amba/src/components/student-portal/ContactCards.css

.contact-grid {
  display: grid;
  grid-template-columns: repeat(1, 1fr);
  gap: 1rem;
  margin: 2rem 1rem;
}

@media (min-width: 768px) {
  .contact-grid {
    gap: 1.5rem;
    margin: 5rem;
  }
}

@media (min-width: 640px) {
  .contact-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

.contact-card {
  padding: 1.5rem;
  border-radius: 1.5rem;
  position: relative;
  overflow: hidden;
  transition: all 0.5s;
  text-decoration: none;
  display: block;
}

@media (min-width: 768px) {
  .contact-card {
    padding: 2rem;
    border-radius: 2.5rem;
  }
}

.contact-card:hover {
  transform: translateY(-0.5rem);
}

.contact-card-dark-red {
  background: linear-gradient(to bottom right, rgba(220, 38, 38, 0.2), rgba(127, 29, 29, 0.4));
  border: 1px solid rgba(239, 68, 68, 0.2);
}

.contact-card-dark-red:hover {
  transform: translateY(-0.5rem);
}

.contact-card-dark-blue {
  background: linear-gradient(to bottom right, rgba(37, 99, 235, 0.2), rgba(30, 58, 138, 0.4));
  border: 1px solid rgba(59, 130, 246, 0.2);
}

.contact-card-dark-blue:hover {
  transform: translateY(-0.5rem);
}

.contact-card-light {
  background: white;
  border: 1px solid #f3f4f6;
  box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
}

.contact-card-light:hover {
  box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15);
}

.contact-card-light-red:hover {
  border-color: #fecaca;
}

.contact-card-light-blue:hover {
  border-color: #bfdbfe;
}

.contact-card-glow {
  position: absolute;
  top: 0;
  right: 0;
  width: 8rem;
  height: 8rem;
  border-radius: 9999px;
  opacity: 0.1;
  transition: all 0.5s;
  margin-top: -4rem;
  margin-right: -4rem;
}

.contact-card-glow-dark-red {
  background-color: #f87171;
}

.contact-card-glow-dark-blue {
  background-color: #60a5fa;
}

.contact-card-glow-light-red {
  background-color: #fecaca;
}

.contact-card-glow-light-blue {
  background-color: #bfdbfe;
}

.contact-card:hover .contact-card-glow {
  transform: scale(1.5);
}

.contact-card-content {
  position: relative;
  z-index: 10;
}

.contact-icon {
  width: 2.5rem;
  height: 2.5rem;
  border-radius: 1rem;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1rem;
  transition: transform 0.3s;
}

@media (min-width: 768px) {
  .contact-icon {
    width: 3.5rem;
    height: 3.5rem;
    margin-bottom: 1.5rem;
  }
}

.contact-card:hover .contact-icon {
  transform: scale(1.1);
}

.contact-icon-dark-red {
  background-color: rgba(239, 68, 68, 0.2);
  color: #f87171;
  border: 1px solid rgba(239, 68, 68, 0.2);
}

.contact-icon-dark-blue {
  background-color: rgba(59, 130, 246, 0.2);
  color: #60a5fa;
  border: 1px solid rgba(59, 130, 246, 0.2);
}

.contact-icon-light-red {
  background-color: #fef2f2;
  color: #dc2626;
}

.contact-icon-light-blue {
  background-color: #eff6ff;
  color: #2563eb;
}

.contact-title {
  font-size: 1.25rem;
  font-weight: 700;
  margin-bottom: 0.5rem;
}

@media (min-width: 768px) {
  .contact-title {
    font-size: 1.5rem;
  }
}

.contact-title-dark {
  color: white;
}

.contact-title-light {
  color: #111827;
}

.contact-desc {
  margin-bottom: 1.5rem;
  font-weight: 500;
  font-size: 0.875rem;
}

@media (min-width: 768px) {
  .contact-desc {
    margin-bottom: 2rem;
  }
}

.contact-desc-dark {
  color: #94a3b8;
}

.contact-desc-light {
  color: #6b7280;
}

.contact-info {
  display: flex;
  align-items: center;
  font-size: 0.75rem;
  font-weight: 900;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  transition: color 0.2s;
}

@media (min-width: 768px) {
  .contact-info {
    font-size: 0.875rem;
  }
}

.contact-info-dark {
  color: white;
}

.contact-info-light {
  color: #111827;
}

.contact-info-light-red:hover {
  color: #dc2626;
}

.contact-info-light-blue:hover {
  color: #2563eb;
}

.contact-info-icon {
  width: 1rem;
  height: 1rem;
  margin-left: 0.5rem;
  transition: transform 0.2s;
}

.contact-card:hover .contact-info-icon {
  transform: translateX(0.25rem);
}

